        "nombre": "string",
        "empresa": "string (opcional)"
      }
    },
    "knowledge": {
      "endpoint": "https://www.angeltourbrasil.com.br/llms.txt",
      "format": "text/plain"
    },
    "sitemap": {
      "endpoint": "https://www.angeltourbrasil.com.br/sitemap-index.xml",
      "format": "application/xml"
    }
  },
  "contact": {
    "email": "angelportobelo@gmail.com",
    "phone": "+5547999679084",
